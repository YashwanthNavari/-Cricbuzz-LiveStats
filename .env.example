# Cricbuzz RapidAPI Credentials
# Get your API key from: https://rapidapi.com/community/api/cricbuzz-cricket
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=cricbuzz-cricket.p.rapidapi.com

# Relational Database Configuration
# Use SQLite for local development:
DATABASE_URL=sqlite:///cricbuzz_db.sqlite

# Or use PostgreSQL for production:
# DATABASE_URL=postgresql://username:password@localhost:5432/cricbuzz_live
